{% extends "base_admin.html.twig" %}
{% block title %}Nouvelle actualité{% endblock %}
{% block body %}
  <h1>Nouvelle actualité</h1>
  <a href="{{ path('admin_post_list') }}" style="color:#1A2B6D">← Retour à la liste</a>

  {{ form_start(form) }}
    {{ form_row(form.title) }}
    {{ form_row(form.content) }}
    <button type="submit" style="margin-top:1rem;background:#28a745">Créer (brouillon)</button>
  {{ form_end(form) }}
{% endblock %}
