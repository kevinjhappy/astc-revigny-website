{% extends "base_admin.html.twig" %}
{% block title %}Éditer — {{ post.title }}{% endblock %}
{% block body %}
  <h1>Éditer l'actualité</h1>
  <a href="{{ path('admin_post_list') }}" class="btn">← Retour à la liste</a>

  {{ form_start(form) }}
    {{ form_row(form.title) }}
    {{ form_row(form.content) }}
    <button type="submit" style="margin-top:1rem;background:#1A2B6D">Enregistrer</button>
  {{ form_end(form) }}
{% endblock %}
