{% extends "base_admin.html.twig" %}
{% block title %}Tournois{% endblock %}
{% block body %}
  <h1>Tournois</h1>
  <a class="btn" href="{{ path("admin_tournament_new") }}">+ Nouveau tournoi</a>

  {% set active = tournaments|filter(t => t.status.value != 'CLOSED') %}
  {% set closed = tournaments|filter(t => t.status.value == 'CLOSED') %}

  <table style="margin-top:1rem">
    <thead><tr><th>Nom</th><th>Début</th><th>Type</th><th>Statut</th><th>Max</th><th></th></tr></thead>
    <tbody>
    {% for t in active %}
      <tr>
        <td>{{ t.name }}</td>
        <td>{{ t.startDate|date("d/m/Y") }}</td>
        <td>{{ t.type.value }}</td>
        <td>{{ t.status.value }}</td>
        <td>{{ t.maxParticipants }}</td>
        <td><a href="{{ path("admin_tournament_detail", {id: t.id}) }}">Voir</a></td>
      </tr>
    {% else %}
      <tr><td colspan="6">Aucun tournoi actif.</td></tr>
    {% endfor %}
    </tbody>
  </table>

  {% if closed|length > 0 %}
    <h2 style="margin-top:2rem;font-size:1.1rem;color:#666">Tournois clôturés</h2>
    <table>
      <thead><tr><th>Nom</th><th>Début</th><th>Type</th><th>Max</th><th></th></tr></thead>
      <tbody>
      {% for t in closed %}
        <tr>
          <td>{{ t.name }}</td>
          <td>{{ t.startDate|date("d/m/Y") }}</td>
          <td>{{ t.type.value }}</td>
          <td>{{ t.maxParticipants }}</td>
          <td><a href="{{ path("admin_tournament_detail", {id: t.id}) }}">Voir</a></td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  {% endif %}
{% endblock %}
