<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Connexion — ASTC Admin</title>
  <style>
    body { font-family: system-ui; background: #f7f8fc; margin:0; }
    .login-form { max-width:380px; margin:5rem auto; background:#fff; padding:2rem; border-radius:8px; box-shadow:0 4px 12px rgba(0,0,0,.08); }
    h1 { color:#1A2B6D; margin-top:0; }
    label { display:block; margin:.5rem 0 .2rem; color:#444; }
    input { width:100%; padding:.6rem; border:1px solid #ccc; border-radius:4px; box-sizing:border-box; }
    button { width:100%; background:#E8721A; color:#fff; border:none; padding:.7rem; border-radius:4px; font-size:1rem; cursor:pointer; margin-top:1rem; }
    .error { background:#ffebee; color:#c62828; padding:.6rem; border-radius:4px; margin-bottom:1rem; }
  </style>
</head>
<body>
  <form method="post" action="{{ path("app_login") }}" class="login-form">
    <h1>Connexion admin</h1>
    {% if error %}<div class="error">{{ error.messageKey|trans(error.messageData, "security") }}</div>{% endif %}
    <label>Email</label>
    <input type="email" name="_username" value="{{ last_username }}" required autofocus>
    <label>Mot de passe</label>
    <input type="password" name="_password" required>
    <input type="hidden" name="_csrf_token" value="{{ csrf_token("authenticate") }}">
    <button type="submit">Se connecter</button>
  </form>
</body>
</html>
