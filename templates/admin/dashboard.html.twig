{% extends "base_admin.html.twig" %}
{% block title %}Dashboard{% endblock %}
{% block body %}
  <h1>Dashboard</h1>
  <div class="stats" style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:2rem">
    <div style="background:#fff;padding:1.5rem;border-radius:6px;text-align:center">
      <div style="font-size:2rem;font-weight:700;color:#E8721A">{{ activeTournaments }}</div>
      <div>Tournois actifs</div>
    </div>
    <div style="background:#fff;padding:1.5rem;border-radius:6px;text-align:center">
      <div style="font-size:2rem;font-weight:700;color:#E8721A">{{ totalMembers }}</div>
      <div>Membres</div>
    </div>
    <div style="background:#fff;padding:1.5rem;border-radius:6px;text-align:center">
      <div style="font-size:2rem;font-weight:700;color:#E8721A">{{ totalRegistrations }}</div>
      <div>Inscriptions</div>
    </div>
  </div>
  <h2>Inscriptions récentes</h2>
  <table>
    <thead><tr><th>Date</th><th>Nom</th><th>Prénom</th><th>Statut</th></tr></thead>
    <tbody>
    {% for r in recentRegistrations %}
      <tr>
        <td>{{ r.registeredAt|date("d/m/Y H:i") }}</td>
        <td>{{ r.lastName }}</td>
        <td>{{ r.firstName }}</td>
        <td>{{ r.status.value }}</td>
      </tr>
    {% else %}
      <tr><td colspan="4">Aucune inscription.</td></tr>
    {% endfor %}
    </tbody>
  </table>
{% endblock %}
