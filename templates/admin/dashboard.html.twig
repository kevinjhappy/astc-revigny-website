{% extends "base_admin.html.twig" %}
{% block title %}Dashboard{% endblock %}
{% block body %}
  <h1>Dashboard</h1>
  <div class="dashboard-stats">
    <div class="stat-card">
      <div class="value">{{ activeTournaments }}</div>
      <div>Tournois actifs</div>
    </div>
    <div class="stat-card">
      <div class="value">{{ totalMembers }}</div>
      <div>Membres</div>
    </div>
    <div class="stat-card">
      <div class="value">{{ totalRegistrations }}</div>
      <div>Inscriptions</div>
    </div>
  </div>
  <h2>Inscriptions récentes</h2>
  <table>
    <thead><tr><th>Date</th><th>Nom</th><th>Prénom</th><th>Statut</th></tr></thead>
    <tbody>
    {% for r in recentRegistrations %}
      <tr>
        <td>{{ r.registeredAt|date("d/m/Y H:i") }}</td>
        <td>{{ r.lastName }}</td>
        <td>{{ r.firstName }}</td>
        <td>{{ r.status.value }}</td>
      </tr>
    {% else %}
      <tr><td colspan="4">Aucune inscription.</td></tr>
    {% endfor %}
    </tbody>
  </table>
{% endblock %}
