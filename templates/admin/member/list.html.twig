{% extends "base_admin.html.twig" %}
{% block title %}Membres{% endblock %}
{% block body %}
  <h1>Membres</h1>
  <form method="get" style="margin-bottom:1rem">
    <input name="q" value="{{ q }}" placeholder="Rechercher par nom, prénom, téléphone…">
    <button type="submit">Rechercher</button>
  </form>
  <a class="btn" href="{{ path("admin_member_new") }}">+ Nouveau membre</a>
  <table style="margin-top:1rem">
    <thead><tr><th>Nom</th><th>Prénom</th><th>Téléphone</th><th>Email</th><th>Actions</th></tr></thead>
    <tbody>
    {% for m in members %}
      <tr>
        <td>{{ m.lastName }}</td>
        <td>{{ m.firstName }}</td>
        <td>{{ m.phone }}</td>
        <td>{{ m.email }}</td>
        <td>
          <a href="{{ path("admin_member_edit", {id: m.id}) }}">Éditer</a>
          &nbsp;
          <form method="post" action="{{ path("admin_member_delete", {id: m.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer ce membre ?')">
            <input type="hidden" name="_token" value="{{ csrf_token("del" ~ m.id) }}">
            <button style="background:#dc3545">Supprimer</button>
          </form>
        </td>
      </tr>
    {% else %}
      <tr><td colspan="5">Aucun membre trouvé.</td></tr>
    {% endfor %}
    </tbody>
  </table>
{% endblock %}
