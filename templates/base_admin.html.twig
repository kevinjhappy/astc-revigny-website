<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Admin ASTC{% endblock %}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: system-ui; margin: 0; background: #f7f8fc; color: #222; }

    /* ── Navigation ── */
    .admin-nav {
      background: #1A2B6D; color: #fff;
      padding: .75rem 1.5rem;
      display: flex; flex-wrap: wrap; align-items: center; gap: .25rem 1.5rem;
    }
    .admin-nav .brand { font-weight: 700; font-size: 1rem; margin-right: auto; }
    .admin-nav a { color: #fff; text-decoration: none; font-weight: 500; padding: .35rem .1rem; }
    .admin-nav a:hover { color: #E8721A; }
    .nav-links { display: flex; flex-wrap: wrap; gap: .25rem 1.25rem; align-items: center; }
    .nav-burger {
      display: none; background: none; border: none; color: #fff;
      font-size: 1.5rem; cursor: pointer; padding: .2rem .4rem; margin-left: auto;
    }

    /* ── Main content ── */
    .admin-main { padding: 1.5rem 2rem; }

    /* ── Tables ── */
    .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    table { border-collapse: collapse; width: 100%; min-width: 400px; }
    th, td { border: 1px solid #ddd; padding: .5rem .75rem; text-align: left; white-space: nowrap; }
    th { background: #1A2B6D; color: #fff; }
    td { white-space: normal; }

    /* ── Buttons & links ── */
    .btn { display: inline-block; background: #E8721A; color: #fff; padding: .4rem 1rem; border-radius: 4px; text-decoration: none; }
    button { background: #1A2B6D; color: #fff; padding: .4rem 1rem; border: none; border-radius: 4px; cursor: pointer; }
    button:hover, .btn:hover { opacity: .85; }

    /* ── Forms ── */
    input[type=text], input[type=email], input[type=password],
    select, textarea {
      border: 1px solid #ccc; padding: .4rem .6rem; border-radius: 4px;
      font-size: 1rem; width: 100%; max-width: 400px;
    }
    label { display: block; margin-top: .75rem; margin-bottom: .2rem; font-weight: 500; }
    form p { margin: .5rem 0; }

    /* ── Flash messages ── */
    .flash-success { background: #d4edda; border: 1px solid #c3e6cb; padding: .5rem 1rem; border-radius: 4px; margin-bottom: 1rem; }
    .flash-error   { background: #f8d7da; border: 1px solid #f5c6cb; padding: .5rem 1rem; border-radius: 4px; margin-bottom: 1rem; }

    /* ── Dashboard stats ── */
    .dashboard-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem; margin-bottom: 2rem;
    }
    .stat-card { background: #fff; padding: 1.5rem; border-radius: 6px; text-align: center; }
    .stat-card .value { font-size: 2rem; font-weight: 700; color: #E8721A; }

    /* ── Responsive ── */
    @media (max-width: 640px) {
      .admin-nav { padding: .6rem 1rem; }
      .nav-burger { display: block; }
      .nav-links { display: none; width: 100%; flex-direction: column; align-items: flex-start; gap: 0; padding: .5rem 0; }
      .nav-links.open { display: flex; }
      .nav-links a { padding: .5rem 0; width: 100%; border-top: 1px solid rgba(255,255,255,.15); }

      .admin-main { padding: 1rem; }

      th, td { padding: .4rem .5rem; font-size: .875rem; }

      .dashboard-stats { grid-template-columns: 1fr; }

      input[type=text], input[type=email], input[type=password],
      select, textarea { max-width: 100%; }

      .btn, button { width: 100%; text-align: center; margin-bottom: .25rem; }
      form[style*="display:inline"] { display: block !important; margin-bottom: .25rem; }
    }
  </style>
</head>
<body class="admin">
  <header class="admin-nav">
    <span class="brand">ASTC Admin</span>
    <button class="nav-burger" aria-label="Menu" onclick="document.getElementById('nav-links').classList.toggle('open')">&#9776;</button>
    <nav class="nav-links" id="nav-links">
      <a href="{{ path('admin_dashboard') }}">Dashboard</a>
      <a href="{{ path('admin_tournament_list') }}">Tournois</a>
      <a href="{{ path('admin_member_list') }}">Membres</a>
      <a href="{{ path('admin_registration_list') }}">Inscriptions</a>
      <a href="{{ path('app_logout') }}">Déconnexion</a>
    </nav>
  </header>
  <main class="admin-main">
    {% for msg in app.flashes('success') %}<div class="flash-success">{{ msg }}</div>{% endfor %}
    {% for msg in app.flashes('error') %}<div class="flash-error">{{ msg }}</div>{% endfor %}
    {% block body %}{% endblock %}
  </main>
  <!-- Confirmation modal -->
  <div id="confirm-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:9000;align-items:center;justify-content:center;padding:1rem">
    <div style="background:#fff;padding:1.5rem 2rem;border-radius:8px;max-width:420px;width:100%;box-shadow:0 8px 32px rgba(0,0,0,.25)">
      <p id="confirm-msg" style="margin:0 0 1.5rem;font-size:1rem;color:#222;line-height:1.5"></p>
      <div style="display:flex;gap:.75rem;justify-content:flex-end;flex-wrap:wrap">
        <button type="button" onclick="closeConfirm()" style="background:#6c757d">Annuler</button>
        <button type="button" id="confirm-ok" style="background:#dc3545">Confirmer</button>
      </div>
    </div>
  </div>

  <script>
    // Auto-wrap tables
    document.querySelectorAll('table').forEach(function(t) {
      var w = document.createElement('div');
      w.className = 'table-wrap';
      t.parentNode.insertBefore(w, t);
      w.appendChild(t);
    });

    // Confirmation modal
    var _confirmForm = null;
    document.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-confirm]');
      if (!btn) return;
      e.preventDefault();
      _confirmForm = btn.closest('form');
      document.getElementById('confirm-msg').textContent = btn.dataset.confirm;
      document.getElementById('confirm-modal').style.display = 'flex';
    });
    document.getElementById('confirm-ok').addEventListener('click', function() {
      if (_confirmForm) _confirmForm.submit();
      closeConfirm();
    });
    function closeConfirm() {
      document.getElementById('confirm-modal').style.display = 'none';
      _confirmForm = null;
    }
    document.getElementById('confirm-modal').addEventListener('click', function(e) {
      if (e.target === this) closeConfirm();
    });
  </script>
</body>
</html>
