<div class="modal" id="registration-modal" role="dialog" aria-modal="true" aria-labelledby="reg-modal-title">
  <div class="modal__content">
    <button class="modal__close" data-close aria-label="Fermer">&times;</button>
    <h2 class="modal__title" id="reg-modal-title">
      Inscription&nbsp;— <span data-tournament-name></span>
    </h2>
    <p class="members-notice" role="alert">
      Ce tournoi est réservé aux membres du club. Votre nom et téléphone doivent correspondre à un membre enregistré.
    </p>
    <form id="registration-form" novalidate>
      <input type="hidden" name="tournamentId">
      <div class="form-group">
        <label for="reg-lastName">Nom *</label>
        <input id="reg-lastName" name="lastName" required autocomplete="family-name">
      </div>
      <div class="form-group">
        <label for="reg-firstName">Prénom *</label>
        <input id="reg-firstName" name="firstName" required autocomplete="given-name">
      </div>
      <div class="form-group">
        <label for="reg-phone">Téléphone *</label>
        <input id="reg-phone" name="phone" type="tel" required autocomplete="tel">
      </div>
      <div class="form-group">
        <label for="reg-email">Email</label>
        <input id="reg-email" name="email" type="email" autocomplete="email">
      </div>
      <button class="btn btn--primary form-submit" type="submit">Envoyer</button>
    </form>
    <div class="modal-feedback" id="modal-feedback" role="alert" aria-live="polite"></div>
  </div>
</div>
