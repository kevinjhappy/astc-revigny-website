<section id="contact" data-aos="fade-up">
  <h2>Contact</h2>
  <div class="divider"></div>
  <div class="contact-grid">
    <div>
      <p><strong>ASTC Revigny</strong><br>Rue du Stade<br>55800 Revigny-sur-Ornain</p>
      <p><a href="https://www.facebook.com/AstcRevigny" target="_blank" rel="noopener">Facebook du club</a></p>
      <button class="btn" id="open-contact-modal" style="margin-top:1rem">Contactez-nous</button>
    </div>
    <div>
      <iframe
        src="https://www.openstreetmap.org/export/embed.html?bbox=4.9737%2C48.8215%2C4.9937%2C48.8315&amp;layer=mapnik&amp;marker=48.8265%2C4.9838"
        loading="lazy"
        title="ASTC Revigny — Rue du Stade, 55800 Revigny-sur-Ornain"
        style="width:100%;height:300px;border:0">
      </iframe>
      <p style="font-size:.8rem;margin-top:.3rem;text-align:right">
        <a href="https://www.openstreetmap.org/?mlat=48.8265&amp;mlon=4.9838#map=17/48.8265/4.9838" target="_blank" rel="noopener">Voir sur OpenStreetMap</a>
      </p>
    </div>
  </div>
</section>

<div class="modal" id="contact-modal">
  <div class="modal-content">
    <button class="close" data-close>&times;</button>
    <h2>Contactez-nous</h2>
    <form id="contact-form">
      <label>Votre email *<input type="email" name="email" required></label>
      <label>Objet *<input type="text" name="subject" required maxlength="150"></label>
      <label>Message *<textarea name="message" required rows="5" style="width:100%;padding:.6rem;border:1px solid #ccc;border-radius:4px;resize:vertical;font-family:inherit"></textarea></label>
      <button class="btn" type="submit" style="margin-top:1rem;width:100%">Envoyer</button>
    </form>
    <div class="modal-feedback" id="contact-feedback"></div>
  </div>
</div>
