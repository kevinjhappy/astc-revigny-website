{% set frMois = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'] %}
<section id="tournaments" class="section section--alt" data-aos="fade-up">
  <div class="container">
    <span class="section-eyebrow">Inscriptions ouvertes</span>
    <h2 class="section-title">Nos tournois</h2>
    <div class="divider"></div>

    {% if tournaments|length == 0 %}
      <div class="empty-state">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <p>Aucun tournoi publié pour le moment.</p>
      </div>
    {% else %}
      <div class="tournaments-grid">
        {% for t in tournaments %}
          {% set remaining = max(0, t.max - t.confirmed) %}
          {% set typeClass = t.type == 'MEMBERS_ONLY' ? 'members' : (t.type == 'TEN_UP' ? 'tenup' : 'open') %}
          <article class="tcard" data-card>
            <div class="tcard__accent tcard__accent--{{ typeClass }}"></div>
            <div class="tcard__head">
              <span class="tcard__badge tcard__badge--{{ typeClass }}">
                {{ t.type == 'OPEN' ? 'Ouvert à tous' : (t.type == 'MEMBERS_ONLY' ? 'Membres uniquement' : 'Ten Up') }}
              </span>
              <div class="tcard__name">{{ t.name }}</div>
              <div class="tcard__dates">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                {{ t.startDate|date('j') }} {{ frMois[t.startDate|date('n') - 1] }} {{ t.startDate|date('Y') }}
                &rarr;
                {{ t.endDate|date('j') }} {{ frMois[t.endDate|date('n') - 1] }} {{ t.endDate|date('Y') }}
              </div>
            </div>
            {% if t.description %}
              <div class="tcard__body">
                <p class="tcard__desc">{{ t.description }}</p>
              </div>
            {% endif %}
            <div class="tcard__foot">
              {% if t.type == 'TEN_UP' %}
                <p class="tcard__tenup">Inscriptions via l'application <strong>Ten&nbsp;Up</strong></p>
              {% else %}
                <div class="tcard__places">
                  Places&nbsp;: <strong>{{ remaining }}</strong>
                </div>
                {% if remaining > 0 %}
                  <button class="btn btn--primary btn--sm"
                          data-register="{{ t.id }}"
                          data-type="{{ t.type }}"
                          data-name="{{ t.name }}">S'inscrire</button>
                {% else %}
                  <button class="btn btn--ghost btn--sm"
                          data-register="{{ t.id }}"
                          data-type="{{ t.type }}"
                          data-name="{{ t.name }}">Liste d'attente</button>
                {% endif %}
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>
